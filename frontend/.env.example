# API base URL for the ComplianceKit backend.
VITE_API_BASE_URL=https://api.compliancekit.com

# Stripe publishable key for Billing Portal redirect / embedded checkout.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Optional: Sentry DSN for client error reporting.
VITE_SENTRY_DSN=

# Base path for the deployed app. Use "/" for custom domain, "/repo-name/" for GitHub Pages project sites.
VITE_BASE_PATH=/
