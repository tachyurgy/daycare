{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "./.tsbuild-node"
  },
  "include": ["vite.config.ts", "playwright.config.ts", "e2e/globalSetup.ts"]
}
