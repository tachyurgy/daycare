# ---- core ----
APP_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:3000
LOG_LEVEL=info
SESSION_COOKIE_DOMAIN=localhost

# ---- database (SQLite, ADR-017) ----
# Plain file path or `file:` URL. Examples:
#   ./ck.db                              (relative — handy for dev)
#   file:/var/lib/compliancekit/ck.db    (production path on the droplet)
# Pragmas (WAL, foreign_keys, busy_timeout) are applied automatically by db.Open.
DATABASE_URL=./ck.db

# ---- AWS / S3 / SES ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme
S3_BUCKET=ck-files
SES_FROM_EMAIL=no-reply@compliancekit.io

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme
STRIPE_PRICE_PRO=price_changeme

# ---- Twilio ----
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=changeme
TWILIO_FROM_NUMBER=+15555550100

# ---- LLM / OCR ----
MISTRAL_API_KEY=changeme
GEMINI_API_KEY=changeme

# ---- signing ----
# 32+ byte random hex or base64 string, used to HMAC magic-link tokens
MAGIC_LINK_SIGNING_KEY=change-me-to-a-32-byte-random-secret-string
