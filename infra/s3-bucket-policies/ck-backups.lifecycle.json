{
    "Rules": [
        {
            "ID": "expire-backups-30d",
            "Status": "Enabled",
            "Filter": {
                "Prefix": "postgres/"
            },
            "Transitions": [
                {
                    "Days": 1,
                    "StorageClass": "STANDARD_IA"
                }
            ],
            "Expiration": {
                "Days": 30
            },
            "NoncurrentVersionExpiration": {
                "NoncurrentDays": 30
            },
            "AbortIncompleteMultipartUpload": {
                "DaysAfterInitiation": 1
            }
        }
    ]
}
